APP_NAME="Menet-Tech Dashboard Go"
APP_ENV=production
HTTP_ADDR=127.0.0.1:8080
SQLITE_PATH=/opt/menettech-go/storage/dashboard.db
STORAGE_PATH=/opt/menettech-go/storage
SESSION_COOKIE_NAME=menettech_session
SESSION_COOKIE_SECURE=true
SESSION_TTL_HOURS=24
LOGIN_MAX_ATTEMPTS=5
LOGIN_WINDOW_MINUTES=15
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=change-me-now

# Optional integration settings (managed from Settings UI after first login)
MIKROTIK_HOST=
MIKROTIK_USER=
MIKROTIK_PASS=
MIKROTIK_TEST_USERNAME=test-user

# Legacy import mode (used only when running: go run ./cmd/api import)
LEGACY_MYSQL_DSN="user:pass@tcp(127.0.0.1:3306)/menettech_dashboard?parseTime=true&charset=utf8mb4"
IMPORT_DRY_RUN=false
