[Unit]
Description=Menet-Tech Go API
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/menettech-go/backend
EnvironmentFile=/opt/menettech-go/backend/.env
ExecStart=/opt/menettech-go/backend/menettech-go api
Restart=always
RestartSec=5
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true
ReadWritePaths=/opt/menettech-go/storage

[Install]
WantedBy=multi-user.target
